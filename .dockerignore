# Keep the build context small and — crucially — keep dev state OUT of the image
# so a container always starts as a fresh, unconfigured app.

# Dependencies / build outputs (reinstalled & rebuilt inside the image)
**/node_modules
**/dist
frontend/dist
backend/node_modules

# Runtime state from the dev machine — must NOT ship in the image.
# The app recreates an empty data dir (and seeds a default admin) on first run.
backend/data
data

# Secrets & local env
.env
**/.env
!/.env.example

# Logs, pids, scratch
logs
*.log
*.pid

# Tooling / VCS / docs
.git
.gitignore
.claude
*.md
start.sh
stop.sh
status.sh

# Editor / OS cruft
.vscode
.idea
.DS_Store
Thumbs.db
