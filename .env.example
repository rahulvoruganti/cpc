# Colruyt Private Cloud (CPC) — runtime configuration template.
#
# Copy to backend/.env for local dev, or pass these as container env vars
# (docker run --env-file / compose `environment:`). Everything here is optional
# at boot — most of it can also be set later in the in-app Settings page, which
# persists to backend/data/settings.json (a runtime volume, not the image).
#
# Leave a value blank to fall back to the app default.

# --- Server ---
PORT=4100
# Set to "true" only if you want the backend to serve the built frontend outside
# of a production image. The Docker image sets NODE_ENV=production, which enables
# it automatically.
# SERVE_FRONTEND=false

# --- Auth (set these for any real deployment) ---
# Long random string used to sign JWTs. CHANGE THIS.
JWT_SECRET=
JWT_EXPIRY=8h
# Password for the auto-seeded "admin" account on first run (empty data dir).
# CHANGE IT AFTER FIRST LOGIN. Defaults to "admin123" if unset.
CPC_ADMIN_PASSWORD=

# --- Proxmox (or configure via Settings → Proxmox connection) ---
PROXMOX_HOST=
PROXMOX_PORT=8006
PROXMOX_NODE=
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=
PROXMOX_VERIFY_SSL=false

# --- Default cloud-init SSH password for provisioned VMs ---
VM_SSH_PASSWORD=

# --- AI assistant (Gemini) — optional ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Approval policy (or configure via Settings → Approval policy) ---
# When "false", requests over the thresholds below need admin approval.
AUTO_APPROVE_DEPLOYMENTS=false
APPROVAL_CPU_THRESHOLD=2
APPROVAL_MEMORY_GB_THRESHOLD=4
APPROVAL_DISK_GB_THRESHOLD=50

# --- Entra ID (Azure AD) SSO — leave blank to disable ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=
